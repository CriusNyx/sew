  },
  "imports": {
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^1.0.6",
    "@mdx-js/esbuild": "npm:@mdx-js/esbuild@^3.1.1",
    "@mdx-js/mdx": "npm:@mdx-js/mdx@^3.1.1",
    "@mdx-js/react": "npm:@mdx-js/react@^3.1.1",
    "@mdx-js/rollup": "npm:@mdx-js/rollup@^3.1.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.1",
    "@tanstack/react-router": "npm:@tanstack/react-router@^1.163.2",
    "@tanstack/router-plugin": "npm:@tanstack/router-plugin@^1.163.2",
    "@types/lodash": "npm:@types/lodash@^4.17.24",
    "@uidotdev/usehooks": "npm:@uidotdev/usehooks@^2.4.1",
    "lodash": "npm:lodash@^4.17.23",
    "react": "npm:react@^19.2.0",
    "react-dom": "npm:react-dom@^19.2.0",
    "@std/assert": "jsr:@std/assert@1",
    "@eslint/js": "npm:@eslint/js@^9.39.1",
    "@types/node": "npm:@types/node@^24.10.1",
    "@types/react": "npm:@types/react@^19.2.14",
    "@types/react-dom": "npm:@types/react-dom@^19.2.3",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@^5.1.1",
    "eslint": "npm:eslint@^9.39.1",
    "eslint-plugin-react-hooks": "npm:eslint-plugin-react-hooks@^7.0.1",
    "eslint-plugin-react-refresh": "npm:eslint-plugin-react-refresh@^0.4.24",
    "globals": "npm:globals@^16.5.0",
    "react-feather": "npm:react-feather@^2.0.10",
    "tailwindcss": "npm:tailwindcss@^4.2.1",
    "typescript": "npm:typescript@~5.9.3",
    "typescript-eslint": "npm:typescript-eslint@^8.48.0",
